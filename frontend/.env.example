# The Base URL for the Dashboard Express backend (e.g. http://host:5000/api).
# This site is served on port 3000 — do NOT point this value at localhost:3000,
# or the blogs/team/gallery/proxy routes will call this app instead of the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Supabase (used directly by some Next API routes in src/app/api/*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here